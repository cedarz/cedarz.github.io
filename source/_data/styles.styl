// ---------------------------------------------------------------
// 移动端水平溢出修复：防止任何元素撑开页面产生右侧空白
// html+body 双层限制，消除 Pisces sidebar 遗留宽度
// ---------------------------------------------------------------
html {
  overflow-x: hidden;
  max-width: 100vw;
}
body {
  overflow-x: hidden;
  max-width: 100vw;
}
// Pisces scheme 在移动端 sidebar 仍可能占用右侧空间
@media (max-width: 991px) {
  .container,
  .main,
  .content-wrap,
  .post-block {
    max-width: 100vw !important;
    box-sizing: border-box;
  }
  .sidebar {
    width: 0 !important;
    min-width: 0 !important;
  }
}
figure.highlight,
pre,
.mermaid {
  max-width: 100%;
  overflow-x: auto;
}

// ---------------------------------------------------------------
// 代码块：统一背景，消除方框感
// figure.highlight 是 Hexo highlight.js 生成的外层容器
// ---------------------------------------------------------------
figure.highlight,
figure.highlight table,
figure.highlight tr,
figure.highlight td.code,
figure.highlight td.code pre {
  background: #eaecef !important;
  border: none !important;
  border-radius: 0 !important;
  box-shadow: none !important;
}

figure.highlight td.gutter,
figure.highlight td.gutter pre {
  background: #eaecef !important;
  border-right: 1px solid #dde1e5 !important;
}

// ---------------------------------------------------------------
// 内联代码：独立灰色背景，不随代码块主题变化
// ---------------------------------------------------------------
:not(pre) > code {
  background: #eaecef !important;
  color: inherit !important;
  border-radius: 3px;
  padding: 2px 4px;
}

// ---------------------------------------------------------------
// 文章正文超链接颜色
// ---------------------------------------------------------------
.post-body a:not(.btn) {
  color: #0593d3;
  border-bottom: none;
  &:hover {
    color: #0477ab;
    text-decoration: underline;
  }
}
