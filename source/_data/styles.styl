// ---------------------------------------------------------------
// 移动端水平溢出修复：防止任何元素撑开页面产生右侧空白
// html+body 双层限制，消除 Pisces sidebar 遗留宽度
// ---------------------------------------------------------------
html {
  overflow-x: hidden;
  max-width: 100vw;
}
body {
  overflow-x: hidden;
  max-width: 100vw;
  font-family: "Noto Sans SC", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.post-body {
  font-family: "Noto Sans SC", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

// ---------------------------------------------------------------
// {% poem %} 标签：居中诗歌排版
// ---------------------------------------------------------------
.post-body .poem {
  text-align: center;
  margin: 1.5em 0;
}

.post-body .poem--perline {
  white-space: pre-line;
}

.post-body .poem--multiline {
  p {
    margin: 0 0 1em;
    text-align: center;

    &:last-child {
      margin-bottom: 0;
    }
  }
}
// Pisces scheme 在移动端 sidebar 仍可能占用右侧空间
@media (max-width: 991px) {
  .container,
  .main,
  .content-wrap,
  .post-block {
    max-width: 100vw !important;
    box-sizing: border-box;
  }
  // 勿将 .sidebar 设为 width:0 —— 会挡住 NexT 侧栏滑出，只剩蒙层
}
figure.highlight,
pre,
.mermaid {
  max-width: 100%;
  overflow-x: auto;
}

// ---------------------------------------------------------------
// 代码块：统一背景，消除方框感
// figure.highlight 是 Hexo highlight.js 生成的外层容器
// ---------------------------------------------------------------
figure.highlight,
figure.highlight table,
figure.highlight tr,
figure.highlight td.code,
figure.highlight td.code pre {
  background: #eaecef !important;
  border: none !important;
  border-radius: 0 !important;
  box-shadow: none !important;
}

figure.highlight td.gutter,
figure.highlight td.gutter pre {
  background: #eaecef !important;
  border-right: 1px solid #dde1e5 !important;
}

// ---------------------------------------------------------------
// 内联代码：独立灰色背景，不随代码块主题变化
// ---------------------------------------------------------------
:not(pre) > code {
  background: #eaecef !important;
  color: inherit !important;
  border-radius: 3px;
  padding: 2px 4px;
}

// ---------------------------------------------------------------
// 文章正文超链接颜色（对齐 lisyarus：#cc6600 / #c60）
// ---------------------------------------------------------------
.post-body a:not(.btn) {
  color: #cc6600;
  border-bottom: none;
  text-decoration: none;

  &:hover {
    color: #cc6600;
    text-decoration: underline;
  }
}

.post-body a:not(.btn) code {
  color: #cc6600;
}
// ---------------------------------------------------------------
// Projects 页面（对齐 lisyarus.github.io/blog/projects.html）
// ---------------------------------------------------------------
.main-inner.page:has(.project-list) .post-block {
  max-width: 800px;
  margin-left: auto;
  margin-right: auto;
}

.project-list {
  margin-top: 0.5em;
}

// 分割线（对齐 lisyarus 原生 <hr> + 固定上下间距）
.project-list > hr.project-divider {
  display: block;
  box-sizing: content-box;
  background: none !important;
  background-image: none !important;
  border: none !important;
  border-top: 1px solid #ccc !important;
  height: 0 !important;
  margin: 0.5em 0 !important;
  padding: 0;
  overflow: visible;
}

.project-item {
  margin: 0;
}

.project-title-wrap {
  text-align: center;
  margin: 1em 0 0.25em;

  p {
    margin: 0;
  }
}

// lisyarus 在 <hr> 与下一标题之间有 <br>
.project-list > hr.project-divider + .project-item .project-title-wrap {
  margin-top: 1em;
}

.project-title {
  display: inline-block;
  font-family: inherit;
  font-size: 1.35em;
  font-weight: 700;
  color: #cc6600;
}

.project-row {
  display: flex;
  gap: 20px;
  align-items: center;

  // Pandoc 偶发把块级元素包进 <p>，需归零 margin 并参与 flex
  > p:has(.project-media),
  > p:has(.project-media-wrap) {
    flex: 1;
    min-width: 0;
    margin: 0;
    line-height: 0;
  }
}

.project-row-reverse {
  flex-direction: row-reverse;
}

.project-desc {
  flex: 1;
  min-width: 0;
  text-align: justify;
  line-height: 1.5;

  p {
    margin: 0 0 1em;

    &:last-child {
      margin-bottom: 0;
    }
  }
}

.project-media-wrap {
  flex: 1;
  min-width: 0;
  line-height: 0;

  p {
    margin: 0;
    line-height: 0;
  }
}

.project-media {
  display: block;
  line-height: 0;
}

.project-image {
  display: block;
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  margin: 20px 0;
  border-radius: 10px;
  box-shadow: 0 0 10px rgba(0, 0, 0, 0.25);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.project-media:hover .project-image {
  transform: translate(-5px, -5px);
  box-shadow: 5px 5px 10px rgba(0, 0, 0, 0.25);
}

.project-image-placeholder {
  display: block;
  width: 100%;
  aspect-ratio: 16 / 9;
  margin: 20px 0;
  border-radius: 10px;
  background: #ececec;
  box-shadow: 0 0 10px rgba(0, 0, 0, 0.08);
}

@media (max-width: 767px) {
  .main-inner.page:has(.project-list) .post-block {
    max-width: 100%;
  }

  .project-row,
  .project-row-reverse {
    flex-direction: column;
    align-items: stretch;
  }

  .project-media-wrap,
  .project-row > p:has(.project-media),
  .project-row > p:has(.project-media-wrap) {
    width: 100%;
  }

  .project-image {
    margin: 12px 0;
  }

  .project-desc {
    text-align: left;
  }
}
