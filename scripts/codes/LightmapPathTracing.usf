float2 InverseConcentricMapping(float2 p)
{

	if (p.x == 0 && p.y == 0) return float2(0, 0);

	float r = sqrt(p.x * p.x + p.y * p.y);
	float theta = atan2(p.y, p.x);
	if (theta < -PI/4) theta += 2*PI;

	float a, b;
	if (theta < PI / 4)
	{
		a = r;
		b = theta * a / (PI/4);
	}
	else if (theta < 3*PI/4)
	{
		b = r;
		a = -(theta - PI/2) * b / (PI/4);
	}
	else if (theta < 5*PI/4)
	{
		a = -r;
		b = (theta - PI) * a / (PI/4);
	}
	else
	{
		b = -r;
		a = -(theta - 3*PI/2) * b / (PI/4);
	}

	float x = (a + 1) / 2;
	float y = (b + 1) / 2;

	return float2(x, y);
}

