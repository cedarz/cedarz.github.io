float3 BilinearQuadWarp(float2 uv, float W00, float W01, float W10, float W11) {




	float a = lerp(W00, W01, .5);
	float b = lerp(W10, W11, .5);
	float u = a == b ? uv.x : (sqrt(lerp(a * a, b * b, uv.x)) - a) / (b - a);
