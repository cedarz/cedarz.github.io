float4 GetBurleyTransmissionProfile(FGBufferData GBufferData, float Thickness)
{


	uint SubsurfaceProfileInt = ExtractSubsurfaceProfileInt(GBufferData);
	float WorldUnitScale = DecodeWorldUnitScale( SSProfilesTexture .Load(int3( 0 , SubsurfaceProfileInt,0)).a)*10.0f;
	float4 MeanFreePath = DecodeDiffuseMeanFreePath( SSProfilesTexture .Load(int3( ( ( 0 +1) +1) , SubsurfaceProfileInt, 0)));
	float3 SurfaceAlbedo =  SSProfilesTexture .Load(int3( ( 0 +1) , SubsurfaceProfileInt, 0)).rgb;
	float3 ScalingFactor = GetSearchLightDiffuseScalingFactor3D(SurfaceAlbedo);
	float4 Output=float4(0,0,0,1);

	float3 r = Thickness / MeanFreePath.xyz;
	Output.xyz= 0.25*SurfaceAlbedo*(exp(-ScalingFactor * r) + 3 * exp(-ScalingFactor * r / 3));
	return Output;
}
