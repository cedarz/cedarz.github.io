	}
}


float InitLightPickingCdf(
	float3 WorldPos,
	float3 WorldNormal,
	uint PrimitiveLightingChannelMask,
	bool IsTransmissiveMaterial,
	inout float LightPickingCdf[ 256 ])
{





	float CdfSum = 0;
	{
		for (uint LightIndex = 0; LightIndex < SceneLightCount; ++LightIndex)
		{
			CdfSum += EstimateLight(LightIndex, WorldPos, WorldNormal, PrimitiveLightingChannelMask, IsTransmissiveMaterial);
			LightPickingCdf[LightIndex] = CdfSum;
		}
	}
	return CdfSum;

}


void SelectLight(float RandSample, int NumLights, inout float LightPickingCdf[ 256 ], out uint LightId, out float LightPickPdf)
{
