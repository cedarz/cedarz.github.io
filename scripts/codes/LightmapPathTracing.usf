	Punctual.SphereSinAlphaSoft = 0;
	Punctual.LineCosSubtended = 1;
	Punctual.Rect = (FRect)0;
	Punctual.bIsRect = false;

	float Energy = EnergyNormalization(a2, Context.VoH, Punctual);

