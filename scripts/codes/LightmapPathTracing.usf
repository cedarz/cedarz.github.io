	{
		int Step = Count / 2;
		int Iterator = LightId + Step;
		if (RandSample < LightPickingCdf[Iterator])
		{
			Count = Step;
		}
		else
		{
			LightId = Iterator + 1;
			Count -= Step + 1;
		}
	}

	LightPickPdf = LightPickingCdf[LightId] - ((LightId > 0) ? LightPickingCdf[LightId - 1] : 0.0);


}

bool SampleLight(
	float3 RandSample,
	float3 WorldPos,
	float3 WorldNormal,
	uint PrimitiveLightingChannelMask,
	bool IsTransmissiveMaterial,
	out int OutLightId,
	out float3 OutDirection,
	out float OutDistance,
	out float3 OutRadianceOverPdf,
	out float OutPdf)
{

	OutLightId = -1;
	OutDirection = 0;
	OutDistance = 0;
	OutRadianceOverPdf = 0;
	OutPdf = 0;

	if (SceneLightCount == 0)
	{

		return false;
	}

	float LightPickingCdf[ 256 ];

	float LightPickingCdfSum = InitLightPickingCdf(WorldPos, WorldNormal, PrimitiveLightingChannelMask, IsTransmissiveMaterial, LightPickingCdf);

	if (LightPickingCdfSum == 0.0)
	{

		return false;
	}

	float LightPickPdf = 0;

	SelectLight(RandSample.x * LightPickingCdfSum, SceneLightCount, LightPickingCdf, OutLightId, LightPickPdf);

	LightPickPdf /= LightPickingCdfSum;

	FLightSample Result = SampleLight(OutLightId, RandSample.yz, WorldPos, WorldNormal);
	OutDirection = Result.Direction;
	OutDistance = Result.Distance;
	OutRadianceOverPdf = Result.RadianceOverPdf / LightPickPdf;
	OutPdf = Result.Pdf * LightPickPdf;

	return true;
}
