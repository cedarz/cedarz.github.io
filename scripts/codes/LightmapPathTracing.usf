	float V = UVW.y;

	float4  RG0 = Texture2DSample( Texture, Sampler, float2(U, V) );
	float4  RG1 = Texture2DSample( Texture, Sampler, float2(U + 1.0f / Size, V) );

	return lerp(RG0, RG1, FracW);
}

